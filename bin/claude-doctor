#!/usr/bin/env bash
# ファイル名: claude-doctor
# 説明: Claude Code セッション環境の一次診断（read-only）。
#       配送障害 (ツール結果が空) の一次切り分けと、リソース残骸の棚卸しを 1 コマンド化する。
# 使い方:
#   claude-doctor          全 6 セクションを診断して ✅/⚠️ レポートを表示
# 出力: 人間可読レポート。修復は実行せず、対処コマンドの提案のみ。常に rc 0。
# 設計: docs/superpowers/specs/2026-07-09-claude-doctor-design.md
# 注: ps/du 等がモダン CLI に alias される環境を想定し、絶対パスで呼ぶ。macOS 前提。

set -uo pipefail

METRICS_DIR="$HOME/.claude/metrics"
METRICS_WARN_BYTES=$((4 * 1024 * 1024))  # 上流 ai-dlc 自動 rotation (5MB) より低い警告線
CONF="$HOME/.tmux/claude.conf"

warn_count=0

section() { printf '\n\033[1m== %s ==\033[0m\n' "$1"; }
ok()      { printf '  ✅ %s\n' "$1"; }
warn()    { printf '  ⚠️  %s\n' "$1"; warn_count=$((warn_count + 1)); }
hint()    { printf '     → %s\n' "$1"; }

# --- 1. cc-daemon socket（配送障害の一次切り分け）---
section "1. cc-daemon socket (pty デーモン)"
daemon_dir="/tmp/cc-daemon-$(id -u)"
if [[ ! -d "$daemon_dir" ]]; then
    warn "デーモンディレクトリ不在: $daemon_dir"
    hint "Claude Code セッションが Bash を実行できない可能性。セッション再起動で再生成される"
else
    socks=$(find "$daemon_dir" -name '*.sock' 2>/dev/null)
    if [[ -z "$socks" ]]; then
        warn "socket が 0 件 ($daemon_dir)"
        hint "配送障害中の可能性が高い。該当セッションを再起動"
    else
        ok "socket $(echo "$socks" | grep -c .) 件"
        while IFS= read -r s; do
            printf '     %s  (mtime: %s)\n' "$s" "$(/usr/bin/stat -f '%Sm' "$s")"
        done <<< "$socks"
    fi
fi

# --- 2. 長期セッション（日単位で走りっぱなしの claude CLI）---
section "2. 長期セッション (etime 1日超)"
# 実 CLI セッションのみ: args が claude で始まり Claude.app (デスクトップ) を含まない
long_sessions=$(/bin/ps -eo pid,etime,rss,args | /usr/bin/awk '
    $4 == "claude" && $2 ~ /-/ && $0 !~ /Claude\.app/ {
        cmd = ""; for (i = 4; i <= NF && i < 9; i++) cmd = cmd " " $i
        printf "%s|%s|%dMB|%s\n", $1, $2, $3 / 1024, cmd
    }')
if [[ -z "$long_sessions" ]]; then
    ok "1日超のセッションなし"
else
    while IFS='|' read -r pid etime rss cmd; do
        warn "PID $pid  up=$etime  $rss $cmd"
    done <<< "$long_sessions"
    hint "pane の作業残を確認して畳む（長期セッションはデーモン再起動をまたぐと配送障害の温床）"
fi

# --- 3. 孤児プロセス（ppid=1 の node/claude 系）---
section "3. 孤児プロセス (ppid=1)"
orphans=$(/bin/ps -eo pid,ppid,etime,rss,args | /usr/bin/awk '
    $2 == 1 && $5 ~ /node$|claude/ && $0 !~ /Claude\.app|Electron/ && $0 ~ /claude|@anthropic/ {
        printf "%s|%s|%dMB\n", $1, $3, $4 / 1024
    }')
if [[ -z "$orphans" ]]; then
    ok "孤児プロセスなし"
else
    while IFS='|' read -r pid etime rss; do
        warn "PID $pid  up=$etime  $rss (親なし node/claude)"
    done <<< "$orphans"
    hint "残骸なら kill <pid>（MCP サーバ残骸のことが多い。数日齢なら安全に落とせる）"
fi

# --- 4. metrics 肥大（~/.claude/metrics/*.jsonl）---
section "4. telemetry 肥大 (${METRICS_DIR})"
found_large=0
if [[ -d "$METRICS_DIR" ]]; then
    while IFS= read -r f; do
        size=$(/usr/bin/stat -f '%z' "$f" 2>/dev/null) || continue
        if (( size > METRICS_WARN_BYTES )); then
            found_large=1
            warn "$(basename "$f"): $((size / 1024 / 1024))MB"
            hint "mv '$f'{,.bak-$(date +%Y%m%d)}  # 手動 rotate（前例: sessions.jsonl.bak-20260425）"
        fi
    done < <(find "$METRICS_DIR" -maxdepth 1 -name '*.jsonl' 2>/dev/null)
fi
(( found_large == 0 )) && ok "4MB 超の jsonl なし"

# --- 5. tmux-claude-voice config drift ---
section "5. config drift (${CONF} vs tmux runtime)"
if [[ ! -f "$CONF" ]]; then
    ok "conf なし（チェック対象外）"
elif ! command -v tmux >/dev/null 2>&1 || ! tmux info >/dev/null 2>&1; then
    ok "tmux セッションなし（チェック対象外）"
else
    drift_found=0
    # conf に存在する @claude_voice_* 全キーを runtime と突合（polling_monitor.sh と同じ抽出規則）
    while IFS= read -r line; do
        key=$(sed -E 's/^set -g @claude_voice_([a-z_]+) .*/\1/' <<< "$line")
        conf_val=$(sed -E 's/.*"([^"]*)".*/\1/' <<< "$line")
        runtime_val=$(tmux show-option -gqv "@claude_voice_${key}" 2>/dev/null)
        if [[ -n "$runtime_val" && "$conf_val" != "$runtime_val" ]]; then
            drift_found=1
            warn "${key}: conf=[$conf_val] runtime=[$runtime_val]"
        fi
    done < <(grep -E '^set -g @claude_voice_[a-z_]+ "' "$CONF")
    if (( drift_found )); then
        hint "意図的トグルなら conf を実態に合わせる / 一時的なら tmux source-file '$CONF' で conf に戻す"
    else
        ok "drift なし"
    fi
fi

# --- 6. git index.lock（カレント repo のみ）---
section "6. git index.lock (cwd)"
if git rev-parse --git-dir >/dev/null 2>&1; then
    lock="$(git rev-parse --git-dir)/index.lock"
    if [[ -f "$lock" ]]; then
        if /bin/ps -eo args | grep -E '^git ' | grep -qv grep; then
            warn "index.lock あり + git プロセス活動中（正常な可能性。完了を待つ）"
        else
            warn "index.lock あり + 活動中 git プロセスなし: $(/usr/bin/stat -f '%Sm' "$lock")"
            hint "/bin/rm -f '$lock'  # 24h 超なら stale 濃厚（rm alias 回避で絶対パス）"
        fi
    else
        ok "index.lock なし"
    fi
else
    ok "git repo でない（チェック対象外）"
fi

# --- サマリ ---
printf '\n\033[1m== 診断完了: '
if (( warn_count == 0 )); then
    printf '問題なし ✅\033[0m\n'
else
    printf '⚠️ %d 件\033[0m\n' "$warn_count"
fi
exit 0
